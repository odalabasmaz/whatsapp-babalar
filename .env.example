# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://babalar:secret@localhost:5432/babalar

# ── AI APIs ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ── Internal ──────────────────────────────────────────────────────────────────
# Ingestion servisi backend'e bu key ile bağlanır
INGEST_API_KEY=CHANGE_ME_RANDOM_HEX

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Ingestion Service ─────────────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
INGEST_CRON=0 2 * * *
