# =============================================================================
# Babalar — AWS Deployment Config
# =============================================================================
# Usage:
#   cp deploy.config.example deploy.config
#   Fill in all CHANGE_ME values in deploy.config
#   ./deploy.sh
#
# deploy.config is in .gitignore — it will never be committed to the repo.
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────
# Profile name configured via `aws configure --profile <name>`.
# Use "default" if you didn't specify a profile name.
AWS_PROFILE=babalar
AWS_REGION=eu-central-1
# 12-digit account number shown in the top-right corner of the AWS Console
AWS_ACCOUNT_ID=CHANGE_ME

# ── Repo ──────────────────────────────────────────────────────────────────────
# URL of the repo the EC2 instance will clone on startup
REPO_URL=https://github.com/YOUR_ORG/babalar.git

# ── Domain & SSL ──────────────────────────────────────────────────────────────
DOMAIN=babalar.example.com

# ACM certificate must be in us-east-1 (CloudFront requirement).
# 1. AWS Console → Certificate Manager → Region: us-east-1 → Request certificate
# 2. Domain: babalar.example.com
# 3. DNS validation → add CNAMEs to your domain provider → wait for "Issued"
# 4. Paste the certificate ARN below:
ACM_CERT_ARN=arn:aws:acm:us-east-1:CHANGE_ME:certificate/CHANGE_ME

# ── Secrets ───────────────────────────────────────────────────────────────────
# These values are uploaded to AWS Secrets Manager by deploy.sh.
# Never commit this file — it's in .gitignore.

# OpenAI API key (platform.openai.com → API Keys)
OPENAI_API_KEY=sk-CHANGE_ME

# JWT signing secret — at least 32 random characters
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# Internal API key shared between the ingestion service and the backend
# Generate: openssl rand -hex 32
INGEST_API_KEY=CHANGE_ME

# PostgreSQL password
# Generate: openssl rand -hex 16
DB_PASSWORD=CHANGE_ME
