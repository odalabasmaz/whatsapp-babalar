# =============================================================================
# Babalar — AWS Deployment Config
# =============================================================================
# Kullanım:
#   cp deploy.config.example deploy.config
#   deploy.config'i düzenle (CHANGE_ME değerlerini doldur)
#   ./deploy.sh
#
# deploy.config .gitignore'a eklidir — commit'e girmez.
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────
# `aws configure --profile <profil>` ile ayarlanmış profil adı.
# Varsayılan profil için "default" yaz.
AWS_PROFILE=default
AWS_REGION=eu-central-1
# AWS Console → sağ üst köşe → hesap numarası (tire olmadan, 12 hane)
AWS_ACCOUNT_ID=CHANGE_ME

# ── Repo ──────────────────────────────────────────────────────────────────────
# EC2'nin clone'layacağı repo URL'i (public repo veya deploy key ile private)
REPO_URL=https://github.com/YOUR_ORG/babalar.git

# ── EC2 ───────────────────────────────────────────────────────────────────────
# EC2 → Key Pairs'te mevcut bir key pair adı.
# Yoksa: aws ec2 create-key-pair --key-name babalar-key --query KeyMaterial --output text > babalar-key.pem
EC2_KEY_PAIR=babalar-key

# ── Domain & SSL ──────────────────────────────────────────────────────────────
DOMAIN=babalar.example.com

# ACM sertifikası CloudFront için us-east-1'de olmalıdır.
# 1. AWS Console → Certificate Manager → Region: us-east-1 → Request certificate
# 2. Domain: babalar.example.com (ve isteğe bağlı *.babalar.example.com)
# 3. DNS validation → CNAME'leri domain sağlayıcına ekle → issued bekle
# 4. Sertifika ARN'ini buraya yapıştır:
ACM_CERT_ARN=arn:aws:acm:us-east-1:CHANGE_ME:certificate/CHANGE_ME

# ── Secrets ───────────────────────────────────────────────────────────────────
# Bu değerler AWS Secrets Manager'a yüklenir.
# Repo'ya commit etme — deploy.config .gitignore'da.

# OpenAI API anahtarı (platform.openai.com → API Keys)
OPENAI_API_KEY=sk-CHANGE_ME

# JWT signing secret — en az 32 karakter rastgele string
# Üretmek için: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# Ingestion servisi ile backend arasındaki dahili API key
# Üretmek için: openssl rand -hex 32
INGEST_API_KEY=CHANGE_ME

# PostgreSQL şifresi — güçlü bir şifre seç
DB_PASSWORD=CHANGE_ME
